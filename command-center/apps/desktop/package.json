{
  "name": "@command-center/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "description": "Operator desktop for the Command Center tracker",
  "author": "Codex",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack:installer": "electron-builder --win nsis -c.artifactName=Command-Center-Setup-${version}-${arch}.${ext}",
    "pack:portable": "electron-builder --win portable -c.artifactName=Command-Center-Portable-${version}-${arch}.${ext}",
    "dist": "electron-vite build && npm run pack:installer && npm run pack:portable",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@command-center/tracker-core": "*",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "chokidar": "^4.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.14"
  },
  "build": {
    "appId": "com.codex.commandcenter",
    "productName": "Command Center",
    "copyright": "Copyright © 2026 Command Center",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js",
      "name": "command-center-desktop"
    },
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp",
      "shortcutName": "Command Center"
    }
  }
}
